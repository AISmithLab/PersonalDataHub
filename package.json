{
  "name": "personaldatahub",
  "version": "0.1.0",
  "description": "Centralized access control layer for personal data",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "pdh": "dist/cli.js"
  },
  "scripts": {
    "build": "node scripts/build-frontend.mjs && tsc && chmod +x dist/cli.js",
    "dev": "node scripts/build-frontend.mjs && tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "setup": "node dist/cli.js init",
    "build:lambda": "esbuild src/lambda.ts src/lambda-seed.ts --bundle --platform=node --target=node22 --outdir=dist-lambda --format=esm --external:better-sqlite3 --external:@aws-sdk/* --minify --tree-shaking=true",
    "build:mobile": "npm run build && node scripts/bundle-mobile.cjs"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.0",
    "@types/sql.js": "^1.4.9",
    "better-sqlite3": "^12.11.1",
    "esbuild": "^0.25.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.750.0",
    "@aws-sdk/lib-dynamodb": "^3.750.0",
    "@hono/node-server": "^1.19.9",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "bcryptjs": "^3.0.3",
    "googleapis": "^171.4.0",
    "hono": "^4.12.1",
    "octokit": "^5.0.5",
    "openai": "^6.38.0",
    "sql.js": "^1.12.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
